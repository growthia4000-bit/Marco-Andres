# Variables compartidas entre local, staging y producción
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SITE_URL=https://tu-dominio.example.com
NEXT_PUBLIC_SITE_NAME=CRM Inmobiliario
OPENROUTER_API_KEY=sk-or-v1-tu-api-key

# SMTP outbound para conversaciones por email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=tu-password-o-app-password
SMTP_SECURE=false
SMTP_FROM_EMAIL=usuario@example.com
SMTP_FROM_NAME=CRM Inmobiliario

# Inbound email real requiere una integracion externa que entregue correos a /api/email/webhook
# Si el destinatario real no coincide con un slug de tenant, puedes fijarlo aqui.
EMAIL_INBOUND_TENANT_SLUG=tu-tenant-slug

# Inbound email real via IMAP polling (ej. Gmail)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=usuario@gmail.com
EMAIL_IMAP_PASS=tu-app-password-imap
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_IMAP_MAX_FETCH=25
EMAIL_SYNC_CRON_SECRET=tu-secret-cron-email-sync

# WhatsApp Cloud API outbound/inbound
WHATSAPP_BUSINESS_TOKEN=tu-token-meta-whatsapp
WHATSAPP_PHONE_NUMBER_ID=tu-phone-number-id
WHATSAPP_VERIFY_TOKEN=tu-verify-token-webhook

# Referencia local recomendada
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Referencia staging recomendada
# NEXT_PUBLIC_SUPABASE_URL=https://staging-proyecto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_SITE_URL=https://staging.example.com

# Referencia producción recomendada
# NEXT_PUBLIC_SUPABASE_URL=https://produccion-proyecto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_SITE_URL=https://app.example.com
